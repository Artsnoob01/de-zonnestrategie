---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calculator from '../components/Calculator.astro';

const schemaMarkup = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "De Zonnestrategie",
    "url": "https://dezonnestrategie.nl",
    "description": "Onafhankelijke uitleg van de Energiewet 2026: wat de nieuwe wet voor Nederlandse consumenten betekent, van energiedelen tot peer-to-peer handel.",
    "inLanguage": "nl-NL",
    "publisher": {
      "@type": "Organization",
      "name": "De Zonnestrategie",
      "url": "https://dezonnestrategie.nl"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Mag ik als particulier echt stroom verkopen aan mijn buurman?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ja. De nieuwe Energiewet introduceert de 'actieve afnemer': een eindafnemer die ook stroom opwekt en deze mag leveren, delen of via P2P verkopen. Je hebt hiervoor geen vergunning nodig, mits je op jaarbasis niet meer levert dan je invoert." }
      },
      {
        "@type": "Question",
        "name": "Wat is het verschil tussen energie delen en peer-to-peer?",
        "acceptedAnswer": { "@type": "Answer", "text": "Bij energie delen rekent je leverancier de stroom administratief toe aan andere klanten — je wordt zelf geen leverancier. Bij peer-to-peer verkoop je stroom via een gereguleerd platform en ontstaat er een leveringsovereenkomst." }
      },
      {
        "@type": "Question",
        "name": "Heb ik een thuisbatterij nodig als de saldering stopt?",
        "acceptedAnswer": { "@type": "Answer", "text": "Niet per se, maar het wordt steeds aantrekkelijker. Zonder saldering ontvang je alleen een terugleververgoeding terwijl je inkoop veel hoger is. Een thuisbatterij laat je meer stroom zelf gebruiken." }
      },
      {
        "@type": "Question",
        "name": "Waarom een dynamisch contract?",
        "acceptedAnswer": { "@type": "Answer", "text": "Met een dynamisch contract betaal je de werkelijke uurprijs van stroom. Als je een thuisbatterij hebt, kun je goedkoop inkopen en duur terugleveren." }
      },
      {
        "@type": "Question",
        "name": "Hoe werken ERE-credits en hoeveel levert dat op?",
        "acceptedAnswer": { "@type": "Answer", "text": "ERE staat voor Emissie Reductie Eenheden. Door de Europese RED3-richtlijn moeten oliemaatschappijen compenseren. Als jij thuis je EV oplaadt via een laadpaal met MID-meter, genereer je die certificaten. De waarde ligt rond €0,10 per kWh." }
      },
      {
        "@type": "Question",
        "name": "Is dit advies onafhankelijk?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ja. De Zonnestrategie is een onafhankelijk informatieplatform zonder affiliate-links of gesponsorde aanbevelingen." }
      }
    ]
  }
]);
---

<BaseLayout
  title="De Zonnestrategie — De Energiewet 2026 uitgelegd voor consumenten"
  description="Van passieve afnemer naar actieve marktdeelnemer. Onafhankelijke uitleg van de Energiewet 2026 en wat de nieuwe rechten voor jou betekenen."
  schemaMarkup={schemaMarkup}
  isLanding={true}
>

<!-- ═══════════════════════ HERO ═══════════════════════ -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <span class="label">Energiewet 2026 · Uitgelegd</span>
        <h1>Van passieve afnemer naar <em>actieve marktdeelnemer</em></h1>
        <p class="hero-sub">De Energiewet geeft jou vanaf 2026 nieuwe rechten en mogelijkheden. Energiedelen, peer-to-peer verkoop, het einde van saldering, ERE-credits — hier vind je wat je nu al kunt, wat nog komt, en wat het voor jouw situatie betekent. Juridisch onderbouwd, onafhankelijk, zonder affiliate-belang.</p>
        <div class="hero-buttons">
          <a href="/kennisbank/" class="btn-primary">Ontdek de Energiewet →</a>
          <a href="#rekentool" class="btn-secondary">Bereken je situatie</a>
        </div>
        <div class="trust-row">
          <div class="trust-item">
            <div class="trust-check">✓</div>
            Juridisch onderbouwd
          </div>
          <div class="trust-item">
            <div class="trust-check">✓</div>
            Onafhankelijk, geen affiliate
          </div>
          <div class="trust-item">
            <div class="trust-check">✓</div>
            Gebaseerd op parlementaire tekst
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card-stack">
          <div class="hero-stat" style="position:relative;">
            <div class="hero-badge">Sinds 2026</div>
            <div class="stat-label">Actieve afnemer</div>
            <div class="stat-value">3 nieuwe rollen</div>
            <div class="stat-detail">Leveren · Delen · Peer-to-peer</div>
          </div>
          <div class="hero-stat">
            <div class="stat-label">Einde saldering</div>
            <div class="stat-value" style="color: var(--sun);">1 jan 2027</div>
            <div class="stat-detail">Zonder afbouw, in één keer</div>
          </div>
          <div class="hero-stat">
            <div class="stat-label">Terugleververgoeding minimum</div>
            <div class="stat-value">50%</div>
            <div class="stat-detail">Van kale leveringstarief, tot 2030 wettelijk geborgd</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ TWO-PATH SPLIT ═══════════════════════ -->
<section class="paths-section">
  <div class="container">
    <div class="section-header">
      <span class="label">Waar wil je beginnen?</span>
      <h2>Twee wegen, één doel: begrijpen wat de Energiewet voor jou betekent</h2>
    </div>
    <div class="paths-grid">
      <a href="/kennisbank/" class="path-card path-kennisbank">
        <div class="path-icon">📚</div>
        <span class="path-tag">Kennisbank</span>
        <h3>Ik wil de Energiewet begrijpen</h3>
        <p>Systematische uitleg van de nieuwe wet: wat is er veranderd, welke rechten heb je, wat mag er wél en wat nog niet. Voor iedereen die verder wil kijken dan de krantenkoppen.</p>
        <ul class="path-topics">
          <li>Nieuwe energietermen in gewoon Nederlands</li>
          <li>Energiedelen, P2P en actieve afnemers</li>
          <li>VvE, huurder, ZZP'er — wat geldt voor wie?</li>
          <li>Wat nog komt: AMvB, EMD-pakket</li>
        </ul>
        <span class="path-cta">Naar de kennisbank →</span>
      </a>
      <a href="#rekentool" class="path-card path-strategy">
        <div class="path-icon">☀️</div>
        <span class="path-tag">Jouw situatie</span>
        <h3>Ik heb zonnepanelen en wil slim kiezen</h3>
        <p>Bereken met onze rekentool wat het einde van saldering voor jou betekent. Gebaseerd op echte EPEX-spotprijzen van 2025. Mét eerlijk advies — ook als dat "niets doen" is.</p>
        <ul class="path-topics">
          <li>Hoeveel kost einde saldering jou concreet?</li>
          <li>Dynamisch contract, thuisbatterij, ERE-credits</li>
          <li>Spotprijzen per dagdeel (EPEX 2025)</li>
          <li>Blog: dynamisch contract, batterij, ERE</li>
        </ul>
        <span class="path-cta">Naar de rekentool →</span>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════ TIMELINE ═══════════════════════ -->
<section class="timeline-section" id="wat-verandert">
  <div class="container">
    <div class="section-header">
      <span class="label">De feiten op een rij</span>
      <h2>Wat verandert er voor zonnepanelenbezitters?</h2>
      <p>De overgang van de Elektriciteitswet 1998 naar de nieuwe Energiewet is de grootste verandering op de energiemarkt in 25 jaar. Dit is wat het voor jou betekent.</p>
    </div>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">1998 — Elektriciteitswet</div>
        <div class="timeline-text">Stroom leveren mocht alleen met vergunning. De consument was <strong>passief</strong>: je kocht stroom van je leverancier, en dat was het.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2023 — Afbouw saldering begint</div>
        <div class="timeline-text">De eerste stap: je mag nog maar <strong>91%</strong> van je teruggeleverde stroom salderen. In 2024 daalt dit naar 82%, in 2025 naar 73% en in 2026 naar 64%.</div>
      </div>
      <div class="timeline-item active">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2026 — De Energiewet treedt in werking</div>
        <div class="timeline-text">De Energiewet vervangt de Elektriciteitswet 1998. De <strong>actieve afnemer</strong> wordt een wettelijk erkende marktrol. Jij mag als zonnepanelenbezitter stroom verkopen aan je buurman — <strong>zonder vergunning</strong>. Energiedelen wordt mogelijk bij dezelfde leverancier.</div>
      </div>
      <div class="timeline-item future">
        <div class="timeline-dot"></div>
        <div class="timeline-year">2027 — Saldering stopt volledig</div>
        <div class="timeline-text">Geen verrekening meer. Je ontvangt alleen nog een <strong>terugleververgoeding</strong> (minimaal 50% van het kale leveringstarief tot 2030). Zelfverbruik, opslag en slim terugleveren worden essentieel.</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ VIER PIJLERS ═══════════════════════ -->
<section id="opties">
  <div class="container">
    <div class="section-header">
      <span class="label">Jouw slim energie-ecosysteem</span>
      <h2>Vier slimme stappen voor na 2027</h2>
      <p>De energietransitie biedt een compleet ecosysteem aan mogelijkheden. Niet alles is voor iedereen nodig — wij helpen je de juiste keuze maken.</p>
    </div>
    <div class="options-grid four-col">
      <div class="option-card">
        <div class="option-icon">☀️</div>
        <h3>Slim terugleveren</h3>
        <p>Met een dynamisch contract verkoop je stroom wanneer de prijs hoog is. De Energiewet geeft je daarnaast drie nieuwe routes: direct leveren, energie delen of peer-to-peer verkoop.</p>
        <div class="option-savings">
          <span class="savings-label">Besparing</span>
          <span class="savings-value">€ 150 – 400/jr</span>
        </div>
        <div>
          <span class="option-tag tag-easy">Dynamisch contract</span>
          <span class="option-tag tag-medium">Energiewet 2026</span>
        </div>
      </div>
      <div class="option-card">
        <div class="option-icon">🔋</div>
        <h3>Thuisbatterij</h3>
        <p>Sla je overschot op en gebruik het 's avonds. Met een dynamisch contract handel je automatisch op prijsverschillen: goedkoop inkopen, duur terugleveren. Zelfverbruik stijgt naar 70-80%.</p>
        <div class="option-savings">
          <span class="savings-label">Besparing</span>
          <span class="savings-value">€ 300 – 700/jr</span>
        </div>
        <div>
          <span class="option-tag tag-easy">21% btw terug</span>
          <span class="option-tag tag-advanced">Slim handelen</span>
        </div>
      </div>
      <div class="option-card">
        <div class="option-icon">🚗</div>
        <h3>Laadpaal + ERE-credits</h3>
        <p>Laad je EV thuis op met je eigen zonnestroom. Dankzij ERE-certificaten verdien je ~€0,10 per geladen kWh — betaald door oliemaatschappijen. Tot €500/jaar extra.</p>
        <div class="option-savings">
          <span class="savings-label">Opbrengst ERE</span>
          <span class="savings-value">€ 200 – 500/jr</span>
        </div>
        <div>
          <span class="option-tag tag-medium">MID-meter vereist</span>
          <span class="option-tag tag-easy">Nieuw in 2026</span>
        </div>
      </div>
      <div class="option-card">
        <div class="option-icon">⚡</div>
        <h3>Energiewet-opties</h3>
        <p>De nieuwe Energiewet erkent jou als 'actieve afnemer'. Je mag stroom verkopen aan je buurman (zonder vergunning), delen via je leverancier, of aanbieden via een P2P-platform.</p>
        <div class="option-savings">
          <span class="savings-label">Potentieel</span>
          <span class="savings-value">Groeiend</span>
        </div>
        <div>
          <span class="option-tag tag-easy">Energie delen 2026</span>
          <span class="option-tag tag-advanced">P2P via platform</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ ERE UITLEG ═══════════════════════ -->
<section style="background: var(--sky);" id="ere">
  <div class="container">
    <div class="explainer-grid">
      <div class="explainer-content">
        <span class="label">Nieuw in 2026</span>
        <h2>ERE-credits: oliemaatschappijen betalen jou</h2>
        <p>Door de Europese RED3-richtlijn moeten brandstofleveranciers hun CO₂-uitstoot compenseren. Dat doen ze door Emissie Reductie Eenheden (ERE's) te kopen — certificaten die aantonen dat er duurzaam is gereden. Als jij thuis laadt, lever jij die certificaten.</p>
        <p>Het resultaat: voor elke kWh die je thuis laadt ontvang je een vergoeding, betaald door Shell, BP en consorten.</p>
        <ul class="benefit-list">
          <li><div class="benefit-icon">💰</div><span><strong>~€0,10 per kWh</strong> — bij 4.000 kWh/jaar is dat €400</span></li>
          <li><div class="benefit-icon">📋</div><span><strong>MID-meter nodig</strong> — een gecertificeerde meter in je laadpaal (niet in de meterkast)</span></li>
          <li><div class="benefit-icon">📝</div><span><strong>Registreer via inboekdienstverlener</strong> — bijv. Vattenfall Thuislaadcashback (min. €0,05/kWh garantie)</span></li>
          <li><div class="benefit-icon">🔌</div><span><strong>Combineer met zonnepanelen</strong> — laad gratis met je eigen stroom én ontvang ERE-vergoeding</span></li>
        </ul>
      </div>
      <div class="explainer-visual">
        <div class="flow-diagram">
          <div class="flow-step"><div class="flow-num">1</div><p><strong>Jij laadt je EV thuis</strong> via een laadpaal met MID-meter</p></div>
          <div class="flow-arrow">↓</div>
          <div class="flow-step"><div class="flow-num">2</div><p><strong>kWh's worden geregistreerd</strong> bij een inboekdienstverlener</p></div>
          <div class="flow-arrow">↓</div>
          <div class="flow-step"><div class="flow-num">3</div><p><strong>ERE-certificaten</strong> worden verhandeld aan brandstofleveranciers</p></div>
          <div class="flow-arrow">↓</div>
          <div class="flow-step"><div class="flow-num" style="background: var(--sun);">€</div><p><strong>Jij ontvangt de vergoeding</strong> — Vattenfall garandeert min. €0,05/kWh</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ ENERGIEWET EXPLAINER ═══════════════════════ -->
<section style="background: var(--sky);" id="energiewet">
  <div class="container">
    <div class="explainer-grid">
      <div class="explainer-visual">
        <div class="flow-diagram">
          <div class="flow-step"><div class="flow-num">1</div><p><strong>Jouw zonnepanelen</strong> wekken stroom op achter je meter</p></div>
          <div class="flow-arrow">↓</div>
          <div class="flow-step"><div class="flow-num">2</div><p><strong>Overschot</strong> wordt ingevoed op het net (fysieke handeling)</p></div>
          <div class="flow-arrow">↓</div>
          <div class="flow-step"><div class="flow-num">3</div><p><strong>Administratieve toerekening</strong> aan een andere afnemer — jouw buurman, VvE, of P2P-platform</p></div>
          <div class="flow-arrow">↓</div>
          <div class="flow-step"><div class="flow-num" style="background: var(--sun);">€</div><p><strong>Jij ontvangt een vergoeding</strong> die hoger kan zijn dan de standaard terugleververgoeding</p></div>
        </div>
      </div>
      <div class="explainer-content">
        <span class="label">Hoe werkt het?</span>
        <h2>Van fysiek invoeden naar slim vermarkten</h2>
        <p>Een belangrijk inzicht: elektronen hebben geen namen of rugnummers. Of jouw buurman letterlijk jóuw stroom gebruikt maakt technisch niet uit — het gaat om een <strong>administratieve toerekening</strong>. En dat is precies waar de nieuwe Energiewet meer mogelijkheden biedt.</p>
        <p>De balanceringsverantwoordelijkheid (het net op 50Hz houden) blijft bij een vergunningplichtige partij. Jij hoeft je daar niet druk over te maken.</p>
        <ul class="benefit-list">
          <li><div class="benefit-icon">⚖️</div><span><strong>Geen vergunning nodig</strong> — mits je niet meer levert dan invoert op jaarbasis</span></li>
          <li><div class="benefit-icon">🛡️</div><span><strong>Consumentenbescherming blijft</strong> — transparante voorwaarden verplicht</span></li>
          <li><div class="benefit-icon">📊</div><span><strong>Dynamische contracten</strong> maken slim verhandelen mogelijk</span></li>
          <li><div class="benefit-icon">🔋</div><span><strong>Thuisbatterij</strong> vergroot je zelfverbruik en flexibiliteit</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ CALCULATOR ═══════════════════════ -->
<Calculator />

<!-- ═══════════════════════ PARTNERS (INFORMATIEF) ═══════════════════════ -->
<section id="partners">
  <div class="container">
    <div class="section-header">
      <span class="label">Onafhankelijke informatie</span>
      <h2>Jouw opties op een rij</h2>
      <p>Geen affiliate-links, geen gesponsorde aanbevelingen. Wij leggen de opties uit zodat jij een weloverwogen keuze maakt.</p>
    </div>
    <div class="partners-grid four-col">
      <div class="partner-card featured">
        <div class="partner-logo">☀️</div>
        <div class="partner-name">Dynamisch contract</div>
        <div class="partner-desc">Betaal de werkelijke uurprijs en profiteer van piektarieven bij teruglevering. De laagdrempeligste stap.</div>
        <ul class="partner-features">
          <li>Geen investering nodig</li>
          <li>Dynamische uurtarieven</li>
          <li>Vaak geen terugleverkosten</li>
          <li>Besparing €150-400/jaar</li>
        </ul>
        <a href="#rekentool" class="partner-btn partner-btn-primary">Bereken je situatie →</a>
      </div>
      <div class="partner-card">
        <div class="partner-logo">🔋</div>
        <div class="partner-name">Thuisbatterij</div>
        <div class="partner-desc">Sla je overschot op en gebruik het zelf. Combineer met een dynamisch contract voor optimaal resultaat.</div>
        <ul class="partner-features">
          <li>Zelfverbruik 70-80%</li>
          <li>Prijzen sterk gedaald</li>
          <li>21% btw terugvorderbaar (KOR)</li>
          <li>Terugverdientijd 6-9 jaar</li>
        </ul>
        <a href="#rekentool" class="partner-btn partner-btn-outline">Bereken je situatie →</a>
      </div>
      <div class="partner-card">
        <div class="partner-logo">🚗</div>
        <div class="partner-name">Slim laden + ERE</div>
        <div class="partner-desc">Laad je EV thuis met zonnestroom en ontvang ERE-credits. Vereist een laadpaal met MID-meter.</div>
        <ul class="partner-features">
          <li>~€0,10/kWh ERE-vergoeding</li>
          <li>Gratis laden met zonnestroom</li>
          <li>MID-meter vereist</li>
          <li>Tot €400/jaar extra</li>
        </ul>
        <a href="#ere" class="partner-btn partner-btn-outline">Lees meer over ERE →</a>
      </div>
      <div class="partner-card">
        <div class="partner-logo">⚡</div>
        <div class="partner-name">Energie delen</div>
        <div class="partner-desc">Deel je stroom met je VvE of buren via je leverancier. In de praktijk nog beperkt beschikbaar.</div>
        <ul class="partner-features">
          <li>Geen leveranciersrol nodig</li>
          <li>Wettelijk mogelijk sinds 2026</li>
          <li>Praktijk nog in opbouw</li>
          <li>Ideaal voor VvE's</li>
        </ul>
        <a href="#energiewet" class="partner-btn partner-btn-outline">Lees meer →</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ FAQ ═══════════════════════ -->
<section class="faq-section" id="faq">
  <div class="container">
    <div class="section-header">
      <span class="label">Veelgestelde vragen</span>
      <h2>Alles wat je wilt weten</h2>
    </div>
    <div class="faq-grid">
      <div class="faq-item">
        <div class="faq-q">Mag ik als particulier echt stroom verkopen aan mijn buurman?<span class="arrow">▾</span></div>
        <div class="faq-a"><p>Ja. De nieuwe Energiewet introduceert de 'actieve afnemer': een eindafnemer die ook stroom opwekt en deze mag leveren, delen of via P2P verkopen. Je hebt hiervoor geen vergunning nodig, mits je op jaarbasis niet meer levert dan je invoert. Wel moet je transparante contractvoorwaarden hanteren en blijft consumentenbeschermingsrecht van toepassing.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Wat is het verschil tussen energie delen en peer-to-peer?<span class="arrow">▾</span></div>
        <div class="faq-a"><p>Bij energie delen rekent je leverancier de stroom administratief toe aan andere klanten — je wordt zelf geen leverancier. Bij peer-to-peer (P2P) verkoop je stroom via een gereguleerd platform en ontstaat er wél een leveringsovereenkomst tussen jou en de afnemer. Het platform is vergunningplichtig, jij niet. P2P biedt meer controle over de prijs, energie delen is eenvoudiger.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Heb ik een thuisbatterij nodig als de saldering stopt?<span class="arrow">▾</span></div>
        <div class="faq-a"><p>Niet per se, maar het wordt steeds aantrekkelijker. Zonder saldering ontvang je alleen een terugleververgoeding (vaak €0,05-0,15/kWh) terwijl je inkoop €0,30-0,50/kWh kost. Een thuisbatterij laat je meer stroom zelf gebruiken en bij een dynamisch contract kun je handelen op prijsverschillen. De btw (21%) is terugvorderbaar als je een dynamisch contract hebt.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Waarom een dynamisch contract?<span class="arrow">▾</span></div>
        <div class="faq-a"><p>Met een dynamisch contract betaal je de werkelijke uurprijs van stroom. Als je een thuisbatterij hebt, kun je goedkoop inkopen (bijvoorbeeld 's nachts) en duur terugleveren (piektarieven). Bovendien rekenen dynamische leveranciers vaak geen terugleverkosten, wat bij vaste contracten €0,03-0,05/kWh kan zijn. Vergelijk meerdere aanbieders op teruglevervoorwaarden — die verschillen sterk.</p></div>
