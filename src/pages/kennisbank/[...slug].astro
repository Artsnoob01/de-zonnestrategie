---
import { getCollection } from 'astro:content';
import KennisbankPost from '../../layouts/KennisbankPost.astro';

export async function getStaticPaths() {
  const articles = await getCollection('kennisbank');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---

<KennisbankPost
  title={article.data.title}
  seoTitle={article.data.seoTitle}
  description={article.data.description}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  cluster={article.data.cluster}
  relatedSlugs={article.data.relatedSlugs}
  slug={article.slug}
>
  <Content />
</KennisbankPost>
