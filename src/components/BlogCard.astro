---
interface Props {
  title: string;
  description: string;
  slug: string;
  publishDate: Date;
  category: string;
  isPillar?: boolean;
}

const { title, description, slug, publishDate, category, isPillar = false } = Astro.props;

const dateStr = publishDate.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryLabels: Record<string, string> = {
  strategie: 'Strategie',
  energiewet: 'Energiewet',
  technologie: 'Technologie',
  financieel: 'Financieel',
};
---

<article class:list={["blog-card", { pillar: isPillar }]}>
  {isPillar && <span class="pillar-badge">Pillar artikel</span>}
  <span class="card-category">{categoryLabels[category] || category}</span>
  <h3><a href={`/blog/${slug}/`}>{title}</a></h3>
  <p>{description}</p>
  <div class="card-meta">
    <time datetime={publishDate.toISOString()}>{dateStr}</time>
    <a href={`/blog/${slug}/`} class="card-link">Lees meer →</a>
  </div>
</article>

<style>
  .blog-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    transition: all 0.3s;
    position: relative;
  }
  .blog-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-4px);
  }
  .blog-card.pillar {
    border-color: var(--sun);
    box-shadow: 0 0 0 1px var(--sun), var(--shadow);
  }
  .pillar-badge {
    position: absolute;
    top: -10px;
    right: 16px;
    background: linear-gradient(135deg, var(--sun), #F7C948);
    color: var(--leaf-dark);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 4px 12px;
    border-radius: 100px;
    text-transform: uppercase;
  }
  .card-category {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--leaf-light);
    background: rgba(45,106,79,0.08);
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 12px;
  }
  h3 { margin-bottom: 10px; }
  h3 a {
    text-decoration: none;
    color: var(--ink);
    transition: color 0.2s;
  }
  h3 a:hover { color: var(--leaf); }
  p {
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }
  time { color: var(--ink-soft); }
  .card-link {
    color: var(--leaf);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }
  .card-link:hover { color: var(--leaf-dark); }
</style>
