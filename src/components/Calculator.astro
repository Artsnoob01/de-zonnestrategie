<script>
  const $ = (id: string) => document.getElementById(id)!;
  const fmt = (n: number) => n.toLocaleString('nl-NL');

  // EPEX 2025 wholesale prices per dagdeel (€/kWh) — bron: ENTSO-E/Datadame
  const SPOT = {
    night:     0.05,  // 00:00-06:00
    morning:   0.12,  // 06:00-12:00
    afternoon: 0.05,  // 12:00-17:00 (incl. negatieve uren)
    evening:   0.14,  // 17:00-22:00 (piek)
    avg:       0.087,
    negativeHoursPct: 0.07,  // 7% van uren negatief
  };

  // Hoeveel % van zonnestroom per dagdeel (zuid-opstelling)
  const SOLAR_DIST = { night: 0, morning: 0.30, afternoon: 0.55, evening: 0.15 };

  const panelsInput = $('panels') as HTMLInputElement;
  const usageInput = $('usage') as HTMLInputElement;
  const tariffInput = $('tariff') as HTMLInputElement;
  const feedinInput = $('feedin') as HTMLInputElement;

  const step1 = $('step-1');
  const step2 = $('step-2');
  const tabs = document.querySelectorAll('.calc-step-tab');

  function showStep(n: number) {
    step1.style.display = n === 1 ? 'block' : 'none';
    step2.style.display = n === 2 ? 'block' : 'none';
    tabs.forEach(t => t.classList.toggle('active', parseInt((t as HTMLElement).dataset.step!) === n));
    if (n === 2) calcStep2();
    document.getElementById('rekentool')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  $('goto-step2').addEventListener('click', () => showStep(2));
  $('goto-step1').addEventListener('click', () => showStep(1));
  tabs.forEach(t => t.addEventListener('click', () => showStep(parseInt((t as HTMLElement).dataset.step!))));

  let state: any = {};

  function updateDaypartBars() {
    const maxPrice = 0.18;
    const parts = [
      { id: 'night',     price: SPOT.night },
      { id: 'morning',   price: SPOT.morning },
      { id: 'afternoon', price: SPOT.afternoon },
      { id: 'evening',   price: SPOT.evening },
    ];
    parts.forEach(p => {
      const pct = Math.max(5, (p.price / maxPrice) * 100);
      $('bar-' + p.id).style.width = pct + '%';
      $('bar-' + p.id + '-val').textContent = '€' + p.price.toFixed(2).replace('.', ',');
    });
  }

  function calcStep1() {
    const panels = parseInt(panelsInput.value);
    const usage = parseInt(usageInput.value);
    const tariff = parseInt(tariffInput.value) / 100;
    const feedin = parseFloat(feedinInput.value) / 100;

    const production = panels * 350;
    const selfUseRatio = 0.35;
    const selfUse = Math.round(Math.min(production * selfUseRatio, usage));
    const surplus = production - selfUse;

    // === Stap 1a: besparing MET saldering (2026, 64%) — vlak berekend ===
    const salderingPct = 0.64;
    const salderedKwh = Math.round(Math.min(surplus * salderingPct, usage - selfUse));
    const savingSelfUse = selfUse * tariff;
    const savingSaldered = salderedKwh * tariff;
    const unsalderedSurplus2026 = surplus - salderedKwh;
    const savingFeedin2026 = unsalderedSurplus2026 * feedin;
    const savingWithSaldering = Math.round(savingSelfUse + savingSaldered + savingFeedin2026);

    // === Stap 1b: besparing ZONDER saldering — per dagdeel op spotprijzen ===
    // Overschot per dagdeel (gebaseerd op zonne-productieverdeling)
    const surplusMorning   = surplus * SOLAR_DIST.morning;    // 30% van overschot
    const surplusAfternoon = surplus * SOLAR_DIST.afternoon;  // 55% van overschot
    const surplusEvening   = surplus * SOLAR_DIST.evening;    // 15% van overschot

    // Terugleververgoeding per dagdeel = spotprijs (wholesale)
    // Bij vast contract: feedin-slider waarde. Bij spotmarkt: werkelijke dagdeelprijs.
    // We tonen het verschil: vast contract vs. spotmarkt-realiteit
    const feedinFlat = surplus * feedin; // Wat je krijgt bij vast contract
    const feedinSpot = // Wat je overschot waard is op de spotmarkt per dagdeel
      surplusMorning   * SPOT.morning +
      surplusAfternoon * SPOT.afternoon +
      surplusEvening   * SPOT.evening;

    const savingWithoutFlat = Math.round(savingSelfUse + feedinFlat);
    const savingWithoutSpot = Math.round(savingSelfUse + feedinSpot);

    const loss = savingWithoutFlat - savingWithSaldering;

    // Dagdeel-breakdown voor display
    const surplusAfternoonRound = Math.round(surplusAfternoon);
    const afternoonRevenue = Math.round(surplusAfternoon * SPOT.afternoon);
    const eveningValue = Math.round(surplusAfternoon * SPOT.evening);
    const batteryPotential = eveningValue - afternoonRevenue;

    // Spotmarkt-mismatch: hoeveel je verliest doordat je overdag teruglevert ipv 's avonds
    const spotMismatch = Math.round(feedinSpot - (surplus * SPOT.evening)); // negatief = je mist geld

    $('panels-val').textContent = panels + ' panelen';
    $('usage-val').textContent = fmt(usage) + ' kWh';
    $('tariff-val').textContent = '€' + tariff.toFixed(2).replace('.', ',') + '/kWh';
    $('feedin-val').textContent = '€' + feedin.toFixed(2).replace('.', ',') + '/kWh';

    $('res-saving-now').textContent = '€ ' + fmt(savingWithSaldering);
    $('res-saving-after').textContent = '€ ' + fmt(savingWithoutFlat);
    $('res-loss').textContent = '– € ' + fmt(Math.abs(loss));
    $('res-production').textContent = fmt(production) + ' kWh';
    $('res-selfuse').textContent = fmt(selfUse) + ' kWh';
    $('res-surplus').textContent = fmt(surplus) + ' kWh';

    // Dagdeel-insight updaten met echte spotmarkt-berekening
    const spotRevenue = Math.round(feedinSpot);
    $('daypart-insight').innerHTML =
      `📊 <strong>Spotmarkt-realiteit:</strong> je ${fmt(surplus)} kWh overschot is op de EPEX-markt ` +
      `<strong>€${fmt(spotRevenue)}/jaar</strong> waard — waarvan ${fmt(surplusAfternoonRound)} kWh in de goedkoopste uren (middag, €${SPOT.afternoon.toFixed(2).replace('.',',')}). ` +
      `Verschuif dat naar de avondpiek (€${SPOT.evening.toFixed(2).replace('.',',')}) en je verdient ` +
      `<strong>€${fmt(batteryPotential)} extra</strong> per jaar.`;

    updateDaypartBars();

    state = {
      panels, usage, tariff, feedin, production, selfUse, surplus,
      savingWithSaldering, savingWithout: savingWithoutFlat, loss,
      surplusMorning, surplusAfternoon, surplusEvening,
      feedinSpot, spotRevenue
    };
  }

  function calcStep2() {
    const { surplus, tariff, feedin, savingWithSaldering, savingWithout, loss, selfUse,
            surplusMorning, surplusAfternoon, surplusEvening, feedinSpot } = state;
    const dynOn = ($('opt-dynamic') as HTMLInputElement).checked;
    const batOn = ($('opt-battery') as HTMLInputElement).checked;
    const p2pOn = ($('opt-p2p') as HTMLInputElement).checked;
    const ereOn = ($('opt-ere') as HTMLInputElement).checked;

    // === Dynamisch contract ===
    // Voordeel 1: geen terugleverkosten (vast contract rekent €0,03-0,05/kWh)
    const dynNoFeedbackCost = 0.04 * surplus;
    // Voordeel 2: je ontvangt de werkelijke spotprijs per dagdeel ipv vaste feedin
    // Spotwaarde per dagdeel vs vaste terugleververgoeding
    const dynSpotGain = feedinSpot - (surplus * feedin); // kan positief of negatief zijn
    const dynamicBenefit = dynOn ? Math.round(dynNoFeedbackCost + Math.max(0, dynSpotGain)) : 0;

    // === Thuisbatterij ===
    // Verschuif middag-overschot (55%, goedkoopste uren) naar eigen avondverbruik
    // Je bespaart het retail-tarief ipv de terugleververgoeding te ontvangen
    const batteryEfficiency = 0.90; // 90% round-trip
    const batteryShiftKwh = batOn ? Math.round(surplusAfternoon * batteryEfficiency) : 0;
    // Winst = verschoven kWh * (retailtarief dat je uitspaart - feedin die je anders had ontvangen)
    const batteryBenefit = batOn ? Math.round(batteryShiftKwh * (tariff - feedin)) : 0;

    // === P2P ===
    // Restoverschot (ochtend + avond overschot + wat middag overblijft) verkopen
    // Tegen iets betere prijs dan feedin (~€0,04/kWh premium)
    const afterBattery = surplus - (batOn ? Math.round(surplusAfternoon) : 0);
    const p2pBenefit = p2pOn ? Math.round(afterBattery * 0.04) : 0;

    // === ERE-credits ===
    const ereKwh = 3000;
    const ereBenefit = ereOn ? Math.round(ereKwh * 0.10) : 0;

    const totalGain = dynamicBenefit + batteryBenefit + p2pBenefit + ereBenefit;
    const net = totalGain + loss;
    const newSaving = savingWithout + totalGain;

    $('res2-loss').textContent = '– € ' + fmt(Math.abs(loss));
    $('res2-dynamic').textContent = '+ € ' + fmt(dynamicBenefit);
    $('res2-battery').textContent = '+ € ' + fmt(batteryBenefit);
    $('res2-p2p').textContent = '+ € ' + fmt(p2pBenefit);
    $('res2-ere').textContent = '+ € ' + fmt(ereBenefit);

    $('row-dynamic').style.display = dynOn ? 'flex' : 'none';
    $('row-battery').style.display = batOn ? 'flex' : 'none';
    $('row-p2p').style.display = p2pOn ? 'flex' : 'none';
    $('row-ere').style.display = ereOn ? 'flex' : 'none';

    const box = $('net-result-box');
    if (net >= 0) {
      box.className = 'net-result-box positive';
      $('net-number').textContent = '+ € ' + fmt(net);
      $('net-sub').textContent = 'per jaar beter af dan met saldering (2026)';
    } else {
      box.className = 'net-result-box negative';
      $('net-number').textContent = '– € ' + fmt(Math.abs(net));
      $('net-sub').textContent = 'resterend verlies — overweeg extra oplossingen';
    }
    $('res2-total-saving').textContent = '€ ' + fmt(newSaving);
  }

  [panelsInput, usageInput, tariffInput, feedinInput].forEach(el =>
    el.addEventListener('input', () => { calcStep1(); if (step2.style.display !== 'none') calcStep2(); })
  );
  [$('opt-dynamic'), $('opt-battery'), $('opt-p2p'), $('opt-ere')].forEach(el =>
    el.addEventListener('change', calcStep2)
  );

  calcStep1();
</script>
