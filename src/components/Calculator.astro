<!-- ═══════════════════════ CALCULATOR ═══════════════════════ -->
<section class="calc-section" id="rekentool">
  <div class="container">

    <!-- ── STEP TABS ── -->
    <div class="calc-steps-nav">
      <button class="calc-step-tab active" data-step="1">
        <span class="step-num">1</span>
        Wat verandert er voor jouw zonnepanelen?
      </button>
      <div class="step-connector"></div>
      <button class="calc-step-tab" data-step="2">
        <span class="step-num">2</span>
        Zo haal je het maximale uit je panelen
      </button>
    </div>

    <!-- ════════════ STEP 1: SALDERING IMPACT ════════════ -->
    <div class="calc-step" id="step-1" style="display: block;">
      <div class="step-header">
        <span class="label">Stap 1 — Jouw situatie</span>
        <h2>Wat verandert er voor jouw zonnepanelen?</h2>
        <p>Vul je situatie in. Wij berekenen wat het einde van saldering voor jou betekent — en of actie nodig is.</p>
      </div>
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="calc-field">
            <label>Aantal zonnepanelen</label>
            <input type="range" id="panels" min="4" max="30" value="12">
            <div class="calc-range-labels"><span>4 panelen</span><span>30 panelen</span></div>
            <div class="calc-value" id="panels-val">12 panelen</div>
          </div>
          <div class="calc-field">
            <label>Jaarlijks stroomverbruik</label>
            <input type="range" id="usage" min="1500" max="8000" value="3500" step="100">
            <div class="calc-range-labels"><span>1.500 kWh</span><span>8.000 kWh</span></div>
            <div class="calc-value" id="usage-val">3.500 kWh</div>
          </div>
          <div class="calc-field">
            <label>Stroomtarief (inkoop per kWh)</label>
            <input type="range" id="tariff" min="20" max="50" value="34" step="1">
            <div class="calc-range-labels"><span>€0,20</span><span>€0,50</span></div>
            <div class="calc-value" id="tariff-val">€0,34/kWh</div>
          </div>
          <div class="calc-field">
            <label>Verwachte terugleververgoeding (na 2027)</label>
            <input type="range" id="feedin" min="3" max="15" value="7" step="0.5">
            <div class="calc-range-labels"><span>€0,03</span><span>€0,15</span></div>
            <div class="calc-value" id="feedin-val">€0,07/kWh</div>
          </div>
        </div>
        <div class="calc-result">
          <div class="result-impact">
            <div class="impact-now">
              <div class="impact-label">Jouw besparing mét saldering <span class="impact-year">(2026, 64%)</span></div>
              <div class="impact-number" id="res-saving-now">€ 1.428</div>
            </div>
            <div class="impact-divider">
              <span class="impact-arrow-down">▼</span>
            </div>
            <div class="impact-after">
              <div class="impact-label">Jouw besparing zónder saldering <span class="impact-year">(2027+)</span></div>
              <div class="impact-number dim" id="res-saving-after">€ 847</div>
              <div class="impact-sub">alleen zelfverbruik + terugleververgoeding</div>
            </div>
          </div>
          <div class="impact-loss-box">
            <div class="loss-label">Jij verliest per jaar</div>
            <div class="loss-number" id="res-loss">– € 581</div>
            <div class="loss-sub">als je niets verandert aan je situatie</div>
          </div>
          <div class="result-breakdown" style="margin-top: 24px;">
            <div class="result-row">
              <span>Geschatte jaarproductie</span>
              <span id="res-production">4.200 kWh</span>
            </div>
            <div class="result-row">
              <span>Direct zelfverbruik (~35%)</span>
              <span id="res-selfuse">1.470 kWh</span>
            </div>
            <div class="result-row">
              <span>Overschot → net</span>
              <span id="res-surplus">2.730 kWh</span>
            </div>
          </div>

          <!-- Dagdeel-analyse -->
          <div class="daypart-analysis" style="margin-top: 24px;">
            <div class="daypart-header">Spotmarktprijzen per dagdeel <span style="font-weight: 400; opacity: 0.5;">(EPEX 2025)</span></div>
            <div class="daypart-bars">
              <div class="daypart-bar">
                <div class="bar-label">Nacht<br><span>00–06</span></div>
                <div class="bar-track"><div class="bar-fill bar-low" id="bar-night"></div></div>
                <div class="bar-value" id="bar-night-val">€0,05</div>
              </div>
              <div class="daypart-bar">
                <div class="bar-label">Ochtend<br><span>06–12</span></div>
                <div class="bar-track"><div class="bar-fill bar-medium" id="bar-morning"></div></div>
                <div class="bar-value" id="bar-morning-val">€0,12</div>
              </div>
              <div class="daypart-bar">
                <div class="bar-label">Middag<br><span>12–17</span></div>
                <div class="bar-track"><div class="bar-fill bar-negative" id="bar-afternoon"></div></div>
                <div class="bar-value" id="bar-afternoon-val">€0,05</div>
              </div>
              <div class="daypart-bar">
                <div class="bar-label">Avond<br><span>17–22</span></div>
                <div class="bar-track"><div class="bar-fill bar-high" id="bar-evening"></div></div>
                <div class="bar-value" id="bar-evening-val">€0,14</div>
              </div>
            </div>
            <div class="daypart-insight" id="daypart-insight">
              ☀️ Je panelen produceren overdag (€0,05/kWh) — maar 's avonds kost stroom €0,14/kWh. Dat verschil is wat een batterij verdient.
            </div>
          </div>

          <button class="result-cta" id="goto-step2" type="button">Dit wil ik oplossen — toon oplossingen →</button>
        </div>
      </div>
    </div>

    <!-- ════════════ STEP 2: SOLUTIONS ════════════ -->
    <div class="calc-step" id="step-2" style="display: none;">
      <div class="step-header">
        <span class="label">Stap 2 — Jouw strategie</span>
        <h2>Zo haal je het maximale uit je panelen</h2>
        <p>Schakel opties aan of uit en zie direct het effect. Soms is de slimste keuze: niets doen.</p>
      </div>
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="solution-toggle-group">
            <label class="solution-toggle">
              <input type="checkbox" id="opt-dynamic" checked>
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
              <span class="toggle-label">
                <strong>Dynamisch contract</strong>
                <small>Handel op uurprijzen, verkoop op piektarieven</small>
              </span>
            </label>
            <label class="solution-toggle">
              <input type="checkbox" id="opt-battery" checked>
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
              <span class="toggle-label">
                <strong>Thuisbatterij</strong>
                <small>Sla overschot op, verhoog zelfverbruik naar ~75%</small>
              </span>
            </label>
            <label class="solution-toggle">
              <input type="checkbox" id="opt-p2p">
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
              <span class="toggle-label">
                <strong>Peer-to-peer verkoop</strong>
                <small>Verkoop restoverschot aan andere huishoudens</small>
              </span>
            </label>
            <label class="solution-toggle">
              <input type="checkbox" id="opt-ere" checked>
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
              <span class="toggle-label">
                <strong>Laadpaal + ERE-credits</strong>
                <small>Verdien ~€0,10/kWh bij thuisladen van je EV</small>
              </span>
            </label>
          </div>
          <button id="goto-step1" type="button" class="back-btn">← Terug naar stap 1</button>
        </div>
        <div class="calc-result">
          <div class="result-comparison">
            <div class="comparison-row loss-row">
              <span>Verlies door einde saldering</span>
              <span class="comp-neg" id="res2-loss">– € 581</span>
            </div>
            <div class="comparison-divider"></div>
            <div class="comparison-row" id="row-dynamic">
              <span>Winst dynamisch contract</span>
              <span class="comp-pos" id="res2-dynamic">+ € 218</span>
            </div>
            <div class="comparison-row" id="row-battery">
              <span>Winst thuisbatterij</span>
              <span class="comp-pos" id="res2-battery">+ € 497</span>
            </div>
            <div class="comparison-row" id="row-p2p" style="display:none;">
              <span>Winst peer-to-peer</span>
              <span class="comp-pos" id="res2-p2p">+ € 135</span>
            </div>
            <div class="comparison-row" id="row-ere">
              <span>Opbrengst ERE-credits (EV laden)</span>
              <span class="comp-pos" id="res2-ere">+ € 300</span>
            </div>
          </div>
          <div class="net-result-box positive" id="net-result-box">
            <div class="net-label">Netto resultaat ten opzichte van saldering (2026)</div>
            <div class="net-number" id="net-number">+ € 134</div>
            <div class="net-sub" id="net-sub">per jaar beter af dan je huidige situatie</div>
          </div>
          <div class="result-breakdown" style="margin-top: 20px;">
            <div class="result-row">
              <span>Nieuwe totale jaarlijkse besparing</span>
              <span id="res2-total-saving">€ 981</span>
            </div>
          </div>
          <a href="#partners" class="result-cta">Lees meer over je opties →</a>
        </div>
      </div>
    </div>

  </div>
</section>

