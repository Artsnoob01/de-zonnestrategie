---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  seoTitle: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  cluster: string;
  relatedSlugs: string[];
  slug: string;
}

const { title, seoTitle, description, publishDate, updatedDate, cluster, slug } = Astro.props;

const dateStr = publishDate.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' });

const clusterLabels: Record<string, string> = {
  basis: 'De basis',
  energiedelen: 'Energiedelen',
  groepen: 'Specifieke groepen',
  toekomst: 'Toekomst & flexibiliteit',
};

const schemaMarkup = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  "author": {
    "@type": "Person",
    "name": "Thierry Boonstra",
    "jobTitle": "Belastingadviseur M&A",
    "worksFor": {
      "@type": "Organization",
      "name": "JSA Tax"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "De Zonnestrategie",
    "url": "https://dezonnestrategie.nl"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dezonnestrategie.nl/kennisbank/${slug}/`
  },
  "isPartOf": {
    "@type": "CreativeWorkSeries",
    "name": "De Energiewet-kennisbank",
    "url": "https://dezonnestrategie.nl/kennisbank/"
  }
});
---

<BaseLayout
  title={seoTitle}
  description={description}
  schemaMarkup={schemaMarkup}
  type="article"
>

<article class="kb-article-page">
  <div class="container">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs" aria-label="Breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/kennisbank/">Kennisbank</a>
      <span>/</span>
      <a href={`/kennisbank/#${cluster}`}>{clusterLabels[cluster] || cluster}</a>
      <span>/</span>
      <span class="current">{title}</span>
    </nav>

    <!-- Header -->
    <header class="article-header">
      <div class="article-meta-top">
        <span class="article-cluster">{clusterLabels[cluster] || cluster}</span>
      </div>
      <h1>{title}</h1>
      <div class="article-meta">
        <time datetime={publishDate.toISOString()}>Gepubliceerd op {dateStr}</time>
        {updatedStr && <span class="updated">· Bijgewerkt op {updatedStr}</span>}
        <span class="author">· Door Thierry Boonstra</span>
      </div>
    </header>

    <!-- Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- Kennisbank CTA -->
    <div class="article-cta">
      <h3>Meer uit de kennisbank</h3>
      <p>De Energiewet-kennisbank groeit elke week. Blader door de clusters of keer terug naar het overzicht.</p>
      <div class="cta-buttons">
        <a href="/kennisbank/" class="btn-primary">Terug naar kennisbank →</a>
        <a href="/#rekentool" class="btn-secondary">Rekentool</a>
      </div>
    </div>
  </div>
</article>

</BaseLayout>

<style>
  .kb-article-page {
    padding-top: 120px;
    padding-bottom: 80px;
  }
  .kb-article-page .container {
    max-width: 780px;
  }

  .breadcrumbs {
    display: flex;
    gap: 8px;
    font-size: 0.85rem;
    margin-bottom: 40px;
    flex-wrap: wrap;
    align-items: center;
  }
  .breadcrumbs a {
    color: var(--leaf);
    text-decoration: none;
  }
  .breadcrumbs a:hover { text-decoration: underline; }
  .breadcrumbs span { color: var(--ink-soft); }
  .breadcrumbs .current {
    color: var(--ink-soft);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 300px;
  }

  .article-header { margin-bottom: 48px; }
  .article-meta-top { margin-bottom: 16px; }
  .article-cluster {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--leaf-light);
    background: rgba(45,106,79,0.08);
    padding: 4px 12px;
    border-radius: 100px;
  }
  .article-header h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .article-meta {
    font-size: 0.88rem;
    color: var(--ink-soft);
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .prose {
    font-size: 1.08rem;
    line-height: 1.8;
    color: var(--ink-soft);
  }
  .prose :global(h2) {
    font-size: 1.5rem;
    color: var(--leaf-dark);
    margin-top: 48px;
    margin-bottom: 16px;
  }
  .prose :global(h3) {
    font-size: 1.2rem;
    color: var(--ink);
    margin-top: 36px;
    margin-bottom: 12px;
  }
  .prose :global(p) {
    margin-bottom: 20px;
    color: var(--ink-soft);
    font-size: 1.08rem;
    line-height: 1.8;
  }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(a) {
    color: var(--leaf);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) { color: var(--leaf-dark); }
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 20px;
    padding-left: 24px;
  }
  .prose :global(li) {
    margin-bottom: 8px;
    line-height: 1.7;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--sun);
    padding-left: 20px;
    margin: 28px 0;
    color: var(--ink);
    font-style: italic;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }
  .prose :global(em) {
    font-size: 0.95rem;
    color: var(--ink-soft);
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: 0.95rem;
  }
  .prose :global(th), .prose :global(td) {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
  }
  .prose :global(th) {
    background: rgba(45,106,79,0.04);
    color: var(--ink);
    font-weight: 600;
  }

  .article-cta {
    background: linear-gradient(135deg, var(--leaf) 0%, var(--leaf-dark) 100%);
    border-radius: var(--radius);
    padding: 40px;
    text-align: center;
    margin-top: 56px;
  }
  .article-cta h3 {
    color: white;
    font-size: 1.4rem;
    margin-bottom: 12px;
  }
  .article-cta p {
    color: rgba(255,255,255,0.8);
    font-size: 0.98rem;
    margin-bottom: 24px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .article-cta .btn-secondary {
    color: var(--sun-light);
    border-color: var(--sun-light);
  }
  .article-cta .btn-secondary:hover {
    background: rgba(255,216,138,0.08);
  }
</style>
